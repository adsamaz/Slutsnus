generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  hostedRooms         Room[]              @relation("HostedRooms")
  roomPlayers         RoomPlayer[]
  leaderboardEntries  LeaderboardEntry[]
  sentFriendships     Friendship[]        @relation("SentFriendships")
  receivedFriendships Friendship[]        @relation("ReceivedFriendships")
  sessionPlayers      GameSessionPlayer[]
  winLossRecords      WinLossRecord[]
}

model Room {
  id        String   @id @default(cuid())
  code      String   @unique
  gameType  String
  hostId    String
  status    String   @default("waiting")
  createdAt DateTime @default(now())

  host     User         @relation("HostedRooms", fields: [hostId], references: [id])
  players  RoomPlayer[]
  sessions GameSession[]
}

model RoomPlayer {
  roomId   String
  userId   String
  ready    Boolean  @default(false)
  joinedAt DateTime @default(now())

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@id([roomId, userId])
}

model GameSession {
  id         String    @id @default(cuid())
  roomId     String
  startTime  DateTime  @default(now())
  endTime    DateTime?
  resultJson String?

  room    Room                @relation(fields: [roomId], references: [id])
  players GameSessionPlayer[]
}

model GameSessionPlayer {
  sessionId String
  userId    String
  score     Int
  rank      Int

  session GameSession @relation(fields: [sessionId], references: [id])
  user    User        @relation(fields: [userId], references: [id])

  @@id([sessionId, userId])
}

model LeaderboardEntry {
  id          String   @id @default(cuid())
  gameType    String
  userId      String
  score       Int
  timeTakenMs Int?
  recordedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([gameType, score(sort: Desc)])
  @@index([gameType, timeTakenMs(sort: Asc)])
}

model Friendship {
  id          String   @id @default(cuid())
  requesterId String
  addresseeId String
  status      String   @default("pending")
  createdAt   DateTime @default(now())

  requester User @relation("SentFriendships", fields: [requesterId], references: [id])
  addressee User @relation("ReceivedFriendships", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}

// Win/loss record per player per game type — upserted on game end (CONTEXT.md locked decision)
model WinLossRecord {
  userId    String
  gameType  String
  wins      Int    @default(0)
  losses    Int    @default(0)

  user User @relation(fields: [userId], references: [id])

  @@id([userId, gameType])
}
