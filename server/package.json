        "cors": "^2.8.5",
        "dotenv": "^17.3.1",
        "express": "^4.21.2",
        "file-type": "^19.6.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "pg": "^8.13.3",
