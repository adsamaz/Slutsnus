{
    "name": "slutsnus",
    "private": true,
    "type": "module",
    "workspaces": [
        "shared",
        "server",
        "client"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev --workspace=server\" \"wait-on tcp:4000 && npm run dev --workspace=client\"",
        "build": "npm run build --workspace=shared && npm run build --workspace=server && npm run build --workspace=client",
        "lint": "eslint \"**/*.{ts,tsx}\" --ignore-pattern node_modules"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "concurrently": "^9.1.2",
        "eslint": "^9.0.0",
        "prettier": "^3.4.2",
        "prisma": "^7.5.0",
        "typescript": "^5.7.3",
        "wait-on": "^9.0.4"
    },
    "dependencies": {
        "@prisma/client": "^7.5.0"
    }
}
